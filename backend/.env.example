# MongoDB Connection String
MONGO_URI=your_mongodb_connection_string_here

# Server Port
PORT=8000

# JWT Secret Key (generate a new random secret key)
SECRET_KEY=your_jwt_secret_key_here

# Cloudinary Configuration
CLOUD_NAME=your_cloudinary_cloud_name
API_KEY=your_cloudinary_api_key
API_SECRET=your_cloudinary_api_secret

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Optional: allow multiple origins (comma-separated). If set, this overrides FRONTEND_URL usage in code.
# Example:
# CORS_ORIGINS=http://localhost:5173,https://your-vercel-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
