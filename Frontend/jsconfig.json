{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "target": "ESNext",
        "checkJs": false,
        "ignoreDeprecations": "6.0"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}